# Sophos Central Dashboard - Environment Variables
# Copy this file to .env and fill in your values

# --- App Settings ---
PORT=3000
SESSION_SECRET=change_this_to_a_long_random_string_at_least_32_chars

# --- Dashboard Login ---
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=SophosAdmin@2026!

# --- Sophos Central API ---
SOPHOS_CLIENT_ID=f17e6299-18f9-4ffd-8765-6a9914362742
SOPHOS_CLIENT_SECRET=your_client_secret_here
SOPHOS_TENANT_ID=34be300f-c828-4a15-bba3-9824011559d9
SOPHOS_BASE_URL=https://api-in01.central.sophos.com
SOPHOS_AUTH_URL=https://id.sophos.com/api/v2/oauth2/token

# --- Cache TTL (seconds) ---
CACHE_TTL=120
